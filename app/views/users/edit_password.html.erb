<div class="container">
<h2>Change Password for <%= @user.name %></h2>

<%= form_with model: @user, url: update_password_user_path(@user), method: :patch, local: true do |f| %>

  <div>
    <%= f.label :password %><br>
    <%= f.password_field :password, placeholder: "New password" %>
  </div>

  <div>
    <%= f.label :password_confirmation %><br>
    <%= f.password_field :password_confirmation, placeholder: "Confirm password" %>
  </div>

  <div>
    <%= f.submit "Update Password" %>
  </div>

<% end %>

</div>