<%= form_with model: @task do |form| %>

<div class="form-group">
<%= form.label :title %>
<%= form.text_field :title %>
</div>

<div class="form-group">
<%= form.label :description %>
<%= form.text_area :description %>
</div>

<div class="form-group">
<%= form.label :priority %>
<%= form.select :priority, Task.priorities.keys %>
</div>

<div class="form-group">
<%= form.label :status %>
<%= form.select :status, Task.statuses.keys %>
</div>

<div class="form-group">
<%= form.label :due_date %>
<%= form.date_field :due_date %>
</div>


<div class="form-group">
  <%= form.label :assigned_to_id, "Assign To" %>

  <%= form.collection_select(
        :assigned_to_id,
        User.order(:name),
        :id,
        :name,
        { prompt: "Select User" },
        class: "form-control"
      ) %>
</div>
<div class="form-group">
<%= form.file_field :files, multiple: true %>
</div>

<div class="form-group">
<%= form.submit "Create" %>
</div>
<div class="form-group">

<%#= form.label :user_id, "Assign To" %>

<%#=form.collection_select :user_id, User.all, :id, :name %>

</div>


<% end %>