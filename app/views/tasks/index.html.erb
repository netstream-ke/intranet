

    <!-- HEADER -->
    <div class="page-header">
      <%= link_to "Add New Assignment", new_task_path, class: "button" %>

      <%= link_to new_task_path, class: "floating-add-button" do %>
        <i class="fas fa-plus"></i>
      <% end %>
    </div>
    <br><br>

    <!-- ================= NEW TASKS ================= -->
    <h2>New Jobs</h2>

    <table>
      <thead>
        <tr>
          <th>Task</th>
          <th>Assigned</th>
          <th>Action</th>
          <th>Reassign</th>
          <th>Delete</th>
          <th>Due</th>
        </tr>
      </thead>

      <tbody>
        <% @not_done_tasks.each do |task| %>
          <tr>
            <td><p><%= task.title %></p></td>
            <td>👤 <%= task.user&.name %></td>

            <td><%= link_to "✏️", edit_task_path(task) %></td>
            <td><%= link_to "🔄", edit_task_path(task) %></td>

            <td>
              <%= button_to task_path(task),
                  method: :delete,
                  data: { confirm: "Delete?" } do %>
                🗑
              <% end %>
            </td>

            <td>
              <% if task.due_date %>
                <% if task.due_in_days < 0 %>
                  <span class="badge overdue">Overdue</span>
                <% elsif task.due_in_days == 0 %>
                  <span class="badge today">Today</span>
                <% else %>
                  <span class="badge upcoming"><%= task.due_in_days %> days</span>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- ================= ONGOING ================= -->
    <br>
    <h2>Jobs In Progress</h2>
    <table>
      <thead>
        <tr>
          <th>Task</th>
          <th>User</th>
          <th>Started</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @ongoing_tasks.each do |task| %>
          <tr>
            <td><%= task.title %></td>
            <td><%= task.user&.name %></td>
            <td><%= task.started_at %></td>
            <td><%= link_to "Edit", edit_task_path(task) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
<br>
<h2>Completed Assignments</h2>
<br>

<% @completed_tasks.each do |task| %>
  <div class="task-card completed-task" data-controller="comments">
    
    <!-- TASK INFO -->
    <h3><%= task.title %></h3>
    <p>
      Completed by: <strong><%= task.user&.name %></strong> |
      Duration: <strong><%= task.duration_in_minutes %> mins</strong>
    </p>

    <!-- FILES -->
    <% if task.files.attached? %>
      <div class="task-files">
        <% task.files.each do |file| %>
          <% if file.image? %>
            <%= image_tag file, width: 100 %>
          <% else %>
            <%= link_to file.filename, rails_blob_path(file, disposition: "attachment") %>
          <% end %>
        <% end %>
      </div>
    <% end %>


    <!-- COMMENT SECTION -->
    <div id="comments-<%= task.id %>" class="comment-section hidden">
      <%= turbo_stream_from "comments_#{task.id}" %>

      <!-- NEW COMMENT FORM -->
     <span> <%= form_with model: [task, Comment.new], local: true, html: { class: "comment-form" } do |f| %>

        <div class="comment-text-area">
        
        <%= f.text_area :content,
                        class: "comment-input",
                        placeholder: "Make a comment..." %></span>
       <span> <%= f.submit "Send", class: "comment-submit" %></span>
        </div>
      <% end %>

      <!-- COMMENTS THREAD -->
      <div class="comment-thread">
        <% task.comments.top_level.each do |comment| %>
          <%= render partial: "comments/comment", locals: { comment: comment } %>
          <% if current_user&.admin? || comment.user == current_user %>
  <%= button_to "Delete",
      comment_path(comment),
      method: :delete,
      data: { confirm: "Delete this comment?" },
      class: "delete-btn" %>
<% end %>

        <% end %>
      </div>
    </div>
  </div>
<% end %>