<h1 class="text-3xl font-bold mb-6">Task Board</h1>

<div class="grid grid-cols-3 gap-6">

<div class="bg-gray-100 p-4 rounded">
<h2 class="font-bold mb-2">Not Done</h2>
<% @not_done.each do |task| %>
<div class="bg-white p-2 mb-2 shadow">
<%= task.title %>
</div>
<% end %>
</div>

<div class="bg-yellow-100 p-4 rounded">
<h2 class="font-bold mb-2">Ongoing</h2>
<% @ongoing.each do |task| %>
<div class="bg-white p-2 mb-2 shadow">
<%= task.title %>
</div>
<% end %>
</div>

<div class="bg-green-100 p-4 rounded">
<h2 class="font-bold mb-2">Completed</h2>
<% @completed.each do |task| %>
<div class="bg-white p-2 mb-2 shadow">
<%= task.title %>
</div>
<% end %>
</div>

</div>